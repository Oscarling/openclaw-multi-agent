# 复制为 .env.local 后按本机路径调整
OPENCLAW_PROJECT_ROOT=/Users/yourname/path/to/openclaw-multi-agent
OPENCLAW_BASE_COMPOSE=/Users/yourname/.openclaw/olympus-deploy.yml
OPENCLAW_OVERRIDE_COMPOSE=/Users/yourname/path/to/openclaw-multi-agent/deploy/agent_argus.override.yml
OPENCLAW_CONTROL_UI_URL=http://localhost:3001
OPENCLAW_AGENT_CONTAINER=agent_argus
OPENCLAW_SIDECAR_CONTAINER=openclaw-sidecar_argus-1
OPENCLAW_BACKUP_PASSPHRASE_FILE=/Users/yourname/.openclaw/secrets/backup_passphrase.txt
